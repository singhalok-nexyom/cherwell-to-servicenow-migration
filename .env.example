# Cherwell API connection
CHERWELL_BASE_URL=https://your-cherwell-server.example.com/CherwellAPI
CHERWELL_CLIENT_ID=your-client-id
CHERWELL_USERNAME=your-username
CHERWELL_PASSWORD=your-password
CHERWELL_GRANT_TYPE=password
CHERWELL_TIMEOUT=30
CHERWELL_VERIFY_SSL=true

# ServiceNow API connection
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password
SERVICENOW_API_VERSION=v1
SERVICENOW_TIMEOUT=30
SERVICENOW_VERIFY_SSL=true

# Migration settings
MIGRATION_BATCH_SIZE=50
MIGRATION_MOCK_MODE=true         # Set to false for live migration
MIGRATION_OUTPUT_DIR=./output
MIGRATION_STATE_FILE=./output/migration_state.json
MIGRATION_LOG_LEVEL=INFO
MIGRATION_AUTO_APPROVE=false     # Set to true for CI/CD pipelines
MIGRATION_MAX_RETRIES=3
MIGRATION_RETRY_DELAY=1.0
MIGRATION_SOURCE_OBJECT_TYPE=Incident
MIGRATION_TARGET_TABLE=incident
